return {
    _all = {
        lpath = "lua/?.lua;lua/?/init.lua",
    },
    -- Pure Lua units (no Neovim): busted
    unit = {
        ROOT = { "test/unit" },
        pattern = "_spec%.lua$",
    },
    default = {
        ROOT = { "test/unit" },
        pattern = "_spec%.lua$",
    },
    -- headless-nvim suite: loads minimal_init first to capture notifications
    nvim = {
        ROOT = { "test/nvim" },
        pattern = "_spec%.lua$",
        helper = "test/nvim/minimal_init.lua",
    },
}
